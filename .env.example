# Tracer environment variables — copy to .env and fill in values

# Static API key checked on every ingest request
TRACER_API_KEY=change-me-to-a-random-secret

# Neon (or local) Postgres connection string
DATABASE_URL=postgresql://user:password@localhost:5432/tracer

# Redis connection string
REDIS_URL=redis://localhost:6379

# arq worker concurrency
ARQ_MAX_JOBS=10
