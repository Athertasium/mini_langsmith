# Tracer environment variables — copy to .env and fill in values

# Static API key checked on every ingest request
TRACER_API_KEY=change-me-to-a-random-secret

# Postgres connection string
# When running via docker compose, the DATABASE_URL in docker-compose.yml
# overrides this with the correct in-network address automatically.
DATABASE_URL=postgresql://tracer:tracer@localhost:5432/tracer

# Redis connection string
# Same override applies for docker compose (redis://redis:6379).
REDIS_URL=redis://localhost:6379

# arq worker concurrency
ARQ_MAX_JOBS=10

# Project name sent with every trace (used by CustomTracer SDK when project= not passed explicitly)
TRACER_NAME=my-project

# --- Dashboard (better-auth) ---
# Generate a random secret: openssl rand -hex 32
BETTER_AUTH_SECRET=change-me-to-a-random-hex-secret

# Public URL the dashboard is served at (used for OAuth callbacks and cookies)
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional OAuth — fill in to enable social login
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
